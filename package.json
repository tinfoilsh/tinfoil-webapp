{
  "name": "tinfoil-chat",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "next dev",
    "dev:backend": "node scripts/dev-simulator.mjs",
    "build": "next build",
    "start": "npx serve out",
    "dev:serve": "node scripts/dev-serve.mjs",
    "lint": "next lint",
    "format": "prettier --write .",
    "prepare": "husky install",
    "find-unused": "ts-unused-exports tsconfig.json",
    "test": "vitest run && playwright test",
    "test:unit": "vitest",
    "test:ui": "playwright test",
    "test:ui:interactive": "playwright test --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@apple/mapkit-loader": "^0.2.1",
    "@braintree/sanitize-url": "^7.1.1",
    "@clerk/nextjs": "^6.21.0",
    "@headlessui/react": "^2.1.1",
    "@heroicons/react": "^2.1.4",
    "@radix-ui/react-alert-dialog": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tinfoilsh/tinfoil-icons": "^1.1.1",
    "autoprefixer": "^10.4.21",
    "boring-avatars": "^2.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "html2pdf.js": "^0.12.1",
    "isomorphic-dompurify": "^2.35.0",
    "katex": "^0.16.22",
    "lottie-web": "^5.13.0",
    "lucide-react": "^0.473.0",
    "mermaid": "^11.12.2",
    "next": "^15.3.3",
    "pako": "^2.1.0",
    "react": "^18",
    "react-dom": "^18",
    "react-icons": "^5.5.0",
    "react-markdown": "^9.0.3",
    "react-qr-code": "^2.0.18",
    "react-syntax-highlighter": "^16.1.0",
    "recharts": "^3.8.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tinfoil": "^1.1.0",
    "uuid": "^11.0.3",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20",
    "@types/pako": "^2.0.4",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.0.16",
    "concurrently": "^9.2.1",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "happy-dom": "^20.0.11",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.2",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.6.12",
    "tailwindcss": "^3.4.7",
    "ts-unused-exports": "^11.0.1",
    "typescript": "^5",
    "vitest": "^4.0.16"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --max-warnings=0 --fix",
      "prettier --write"
    ],
    "*.{json,css,scss,md,mdx}": [
      "prettier --write"
    ]
  }
}
